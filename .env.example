# ============================================================
# bs_lab 环境配置模板
# 复制为 .env.local 后修改，.env.local 不会提交到 Git
#
# 开发环境：直接修改 .env.local
# 生产环境：服务器 /opt/bs-lab/.env.local，DB 和 MinIO 用独立资源
# ============================================================

# ── 数据库 ──
# 开发：DATABASE_URL=mysql://root:password@10.0.181.204:13306/bs_exp_data
# 生产：DATABASE_URL=mysql://root:password@10.0.181.204:13306/bs_exp_data_prod
DATABASE_URL=mysql://root:your_password@host:port/your_db

# 或逐字段配置（与 DATABASE_URL 二选一）
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD=
# DB_NAME=bs_exp_data

# ── Redis（可选，当前未强制依赖） ──
# REDIS_URL=redis://:password@host:6379

# ── MinIO（S3 兼容存储） ──
# 开发：MINIO_BUCKET=bslab-media
# 生产：MINIO_BUCKET=bslab-media-prod
MINIO_ENDPOINT=http://localhost:9000
MINIO_BUCKET=bslab-media
MINIO_REGION=us-east-1
MEDIA_APP_ACCESS_KEY=minio
MEDIA_APP_SECRET_KEY=minio_secret_key
MEDIA_MIRROR_TO_MINIO=1
# 公网访问地址（与 Nginx 反代地址一致），可不填
# MINIO_PUBLIC_URL=https://lab.aliberg.cn

# ── 反馈桶（与主桶分开） ──
# MINIO_FEEDBACK_BUCKET=bs-lab-feedback

# ── FFmpeg（视频封面抽帧；服务器安装后可直接用命令名） ──
# 开发：FFMPEG_PATH=D:\soft\ffmpeg-8.1-essentials_build\bin\ffmpeg.exe
# 生产：无需配置（apt install ffmpeg 后 PATH 中可执行）
# FFMPEG_PATH=ffmpeg
# FFPROBE_PATH=ffprobe

# ── AI（LangGraph Agent 服务） ──
# Python LangGraph Agent 服务地址（替换原石头老师网关）
# 启动方式: cd agents-service && uvicorn main:app --port 5001
AGENTS_SERVICE_BASE_URL=http://localhost:5001
# 请求超时时间（毫秒），默认 120000
# AGENTS_SERVICE_TIMEOUT_MS=120000

# ── Agent 服务 LLM 配置 ──
# LLM_API_KEY=sk-your-deepseek-key
# LLM_BASE_URL=https://api.deepseek.com/v1
# LLM_MODEL=deepseek-chat

# ── Agent 服务数据库 ──
# MySQL 业务数据（与后端共用）
# DATABASE_URL=mysql+aiomysql://root:password@10.0.181.204:13306/bs_exp_data
# PostgreSQL Checkpointer（LangGraph 持久化，可选）
# POSTGRES_URL=postgresql+psycopg://bs_lab:changeme@localhost:5432/bs_lab_agents

# ── 向后兼容（旧版网关地址，新版使用 AGENTS_SERVICE_BASE_URL） ──
# STONE_TEACHER_BOT_BASE_URL=http://localhost:5000
# STONE_TEACHER_BOT_TIMEOUT_MS=120000

# ── 应用 ──
PORT=4100
# 服务器部署（PM2 / systemd）：NODE_ENV=production，dev-entry.mjs 自动设为 development
# .env.local 中可以不写 NODE_ENV，dev 启动入口会强制覆盖为 development
# 生产环境下必须配置 MINIO_PUBLIC_URL（见 MinIO 配置区）
NODE_ENV=production
NEXT_PUBLIC_NEW_CORE_API_BASE=http://localhost:4100
NEXT_PUBLIC_EXPERIMENT_CATALOG_TENANT_ID=district-001

# ── 教师素材类型（默认读 `edu_teacher_material_types`，不需手动配置） ──
# BS_LAB_TEACHER_MATERIAL_TYPE_SCHEMA=v2

# ── 其他 ──
DB_POOL_SIZE=10
MEDIA_USE_MYSQL=1
MEDIA_BACKGROUND_LOOP_MS=0
THUMB_MAX_SOURCE_BYTES=524288000
THUMB_FFMPEG_TIMEOUT_MS=120000
THUMB_FFPROBE_TIMEOUT_MS=60000
