# Database (new empty database)
DATABASE_URL=mysql://root:your_password@10.0.181.204:13306/bs_lab_data
# 教师素材类型：后端默认读 `edu_teacher_material_types`（迁移 0019），不要求再建 `teacher_material_type`。
# 仅当目标库只有 0033 私有表时设为 v2：BS_LAB_TEACHER_MATERIAL_TYPE_SCHEMA=v2

# Redis
REDIS_URL=redis://:your_redis_password@10.0.181.204:26739

# Tencent COS
TENCENT_COS_SECRET_ID=
TENCENT_COS_SECRET_KEY=
TENCENT_COS_REGION=ap-shanghai
TENCENT_COS_BUCKET=

# MinIO（S3 兼容；与 presign 上传/下载共用同一客户端）
MINIO_ENDPOINT=http://localhost:9000
MINIO_BUCKET=bs-media
# 可选；MinIO 单区部署常用 us-east-1（与 AWS SDK 默认一致）
MINIO_REGION=us-east-1
MEDIA_APP_ACCESS_KEY=media-app
MEDIA_APP_SECRET_KEY=media-app-secret-please-change
# 为 1 时：/api/media/upload 仅写 MinIO（storage_engine=S3），后端 /v1/media/stream 将签名跳转到对象存储。
# 为 0 或未设置：仅写本地并登记（storage_engine=LOCAL）。
MEDIA_MIRROR_TO_MINIO=0

# data_file 上传后写 logo_url（缩略图/视频封面）；视频抽帧需本机 ffmpeg/ffprobe 在 PATH（或显式路径）
# DATA_FILE_THUMB_IMAGE_REUSE_MAX_BYTES=393216
# DATA_FILE_THUMB_IMAGE_REUSE_MAX_EDGE=720
# DATA_FILE_THUMB_MAX_EDGE=480
# DATA_FILE_THUMB_JPEG_QUALITY=82
# FFMPEG_PATH=ffmpeg
# FFPROBE_PATH=ffprobe

# AI
DEEPSEEK_API_KEY=
AI_CHAT_QWEN_API_KEY=
AI_CHAT_USE_QWEN_API_KEY=1
AI_CHAT_PROVIDER=openai_compatible
AI_CHAT_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
AI_CHAT_MODEL=qwen-turbo

# App
PORT=4100
NODE_ENV=development
# 填「协议 + 主机 + 端口」即可，勿在末尾加 /api；V2 路径恒为 {origin}/v2/…（代码会对误配的 /api 做纠正）
NEXT_PUBLIC_NEW_CORE_API_BASE=http://localhost:4100
# 可选：教学维度页调用的 Next BFF 源（`/api/edu/*`）。留空则使用浏览器同源相对路径（推荐本地）。
# NEXT_PUBLIC_EDU_DIMENSION_API_ORIGIN=http://localhost:4200
# 标准实验目录库 tenant_id（与 DB 种子 SEED_TENANT_ID 一致；多租户部署时按区配置）
NEXT_PUBLIC_EXPERIMENT_CATALOG_TENANT_ID=district-001
# 可选：后端解析目录请求时，未带 x-tenant-id 的默认租户（应与种子一致；通常与上一项同值）
# EXPERIMENT_CATALOG_DEFAULT_TENANT_ID=district-001
# 实验材料主档 tenant_id（与 edu_experimental_materials 种子一致；不填时由 org-district-xh 映射到 org-school-east）
# NEXT_PUBLIC_EXPERIMENTAL_MATERIALS_TENANT_ID=org-school-east

# new-core 后端（与 materials 等 MySQL 仓库共用）
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=bs_lab_data
DB_POOL_SIZE=10

# 媒体中台：MYSQL 持久化与本地文件根目录（storage_engine=LOCAL 时读取 uploads 下路径）
# 默认行为：只要已配置 DATABASE_URL 或 DB_HOST/DB_USER/DB_NAME，就自动启用 MySQL 持久化。
# 如需临时切回纯内存模式，可显式设为 0；需要强制启用时可设为 1。
MEDIA_USE_MYSQL=
MEDIA_LOCAL_UPLOAD_ROOT=uploads
# 每间隔毫秒跑 Outbox + 内存任务消化 +（启用媒体 MySQL 持久化时）缩略图任务；0 表示关闭
MEDIA_BACKGROUND_LOOP_MS=0

# 缩略图 Worker（FFmpeg/Sharp；容器内需可执行 ffmpeg/ffprobe，内网 MINIO_ENDPOINT 需可被 Worker 解析）
THUMB_MAX_SOURCE_BYTES=524288000
THUMB_FFMPEG_TIMEOUT_MS=120000
THUMB_FFPROBE_TIMEOUT_MS=60000
# 可选：自定义二进制路径（默认 PATH 内 ffmpeg / ffprobe）
# FFMPEG_PATH=ffmpeg
# FFPROBE_PATH=ffprobe

# 前端：与后端 sys_media_scopes.subject_key 对齐，无用户联调示例 GROUP:chem_01
NEXT_PUBLIC_MEDIA_SUBJECT_KEY=SYSTEM:bootstrap
