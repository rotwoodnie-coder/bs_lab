#!/bin/bash
#
# bs_lab pre-commit 钩子
# 检测违反规则的代码在提交之前被拦截
#
# 启用方式（在仓库根目录执行一次）：
#   git config core.hooksPath .githooks
#
# 跳过方式（紧急提交）：
#   git commit --no-verify

RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
NC='\033[0m'
FAIL=0

echo ""
echo "╔════════════════════════════════════════════╗"
echo "║  bs_lab 提 交 前 检 查                     ║"
echo "╚════════════════════════════════════════════╝"
echo ""

# ── 辅助函数 ──────────────────────────────────
has_staged() {
  local pattern="$1"
  git diff --cached --name-only --diff-filter=ACMR | grep -qE "$pattern" 2>/dev/null
}

# ── 1. data_role 写入保护 ─────────────────────────
if has_staged '^backend/'; then
  STAGED_BACKEND=$(git diff --cached --name-only --diff-filter=ACMR | grep -E '^backend/' | tr '\n' ' ')

  # 扫描 INSERT INTO data_role
  INSERT_COUNT=$(git diff --cached -U0 -- $STAGED_BACKEND 2>/dev/null | grep -cE 'INSERT\s+INTO\s+[`"'"'"']?data_role[`"'"'"']?' || true)

  if [ "$INSERT_COUNT" -gt 0 ] 2>/dev/null; then
    echo "${RED}[FAIL] data_role 写入检测${NC}"
    echo "       提交中包含 ${INSERT_COUNT} 处对 data_role 表的 INSERT 语句。"
    echo "       data_role 是只读字典表，变更必须通过迁移脚本 (database/migrations/00NN_*.sql)。"
    echo "       移除相关行后重试，或使用 git commit --no-verify 强制提交。"
    echo ""
    FAIL=1
  fi

  # 扫描 UPDATE/DELETE data_role（双保险）
  MUTATE_COUNT=$(git diff --cached -U0 -- $STAGED_BACKEND 2>/dev/null | grep -cE '(UPDATE|DELETE)\s+(FROM\s+)?[`"'"'"']?data_role[`"'"'"']?' || true)

  if [ "$MUTATE_COUNT" -gt 0 ] 2>/dev/null; then
    echo "${RED}[FAIL] data_role 写入检测${NC}"
    echo "       提交中包含 ${MUTATE_COUNT} 处对 data_role 表的 UPDATE/DELETE 语句。"
    echo "       data_role 是只读字典表，变更必须通过迁移脚本。"
    echo ""
    FAIL=1
  fi
fi

# ── 2. 超长函数提醒（超过 60 行） ──────────────
if has_staged '\.(ts|tsx)$'; then
  STAGED_TS=$(git diff --cached --name-only --diff-filter=ACMR | grep -E '\.(ts|tsx)$' | tr '\n' ' ')
  WARN_FUNC=""

  for f in $STAGED_TS; do
    [ ! -f "$f" ] && continue

    # 获取 stage 中该文件的差异
    DIFF=$(git diff --cached -U0 "$f" 2>/dev/null) || continue

    # 查找新增的函数定义
    NEW_FUNCS=$(echo "$DIFF" | grep -E '^\+\s*(export\s+)?(async\s+)?function\s+\w+\s*\(|^\+\s*(export\s+)?(const|let|var)\s+\w+\s*=\s*(async\s+)?\(|^\+\s*(export\s+)?(const|let|var)\s+\w+\s*=\s*(async\s+)?function' || true)

    if [ -n "$NEW_FUNCS" ]; then
      WARN_FUNC="${WARN_FUNC}  ${f}: $(echo "${NEW_FUNCS}" | head -3 | sed 's/^+//' | tr '\n' ' ')"$'\n'
    fi
  done

  if [ -n "$WARN_FUNC" ]; then
    echo "${YELLOW}[SCAN] 以下文件新增了函数定义，请目视检查是否超过 60 行：${NC}"
    echo "$WARN_FUNC" | while IFS= read -r line; do
      [ -n "$line" ] && echo "       $line"
    done
    echo "       建议：超过 60 行的函数应拆分为私有函数或工具函数。"
    echo ""
  fi
fi

# ── 3. 繁体字扫描 ──────────────────────────────────
if has_staged '\.(ts|tsx|mdc|sql|md)$'; then
  STAGED_TEXT=$(git diff --cached --name-only --diff-filter=ACMR | grep -E '\.(ts|tsx|mdc|sql|md)$' | tr '\n' ' ')
  TRAD_COUNT=""

  for f in $STAGED_TEXT; do
    [ ! -f "$f" ] && continue
    HITS=$(git diff --cached -U0 "$f" 2>/dev/null | grep -E '^\+' | grep -E '請|實|說|點|擊|關|閉|開|啟|資|料|圖|示|範|圍|錄|入|步|驟|選|擇|頁|麼|為|與|會|後|臺|審|核' || true)
    if [ -n "$HITS" ]; then
      TRAD_COUNT="${TRAD_COUNT}  ${f}:"$'\n'
      TRAD_COUNT="${TRAD_COUNT}$(echo "${HITS}" | head -5 | sed 's/^+/    > /')"$'\n'
    fi
  done

  if [ -n "$TRAD_COUNT" ]; then
    echo "${RED}[FAIL] 繁体字检测${NC}"
    echo "       新增代码中包含繁体字："
    echo "$TRAD_COUNT"
    echo "       请将繁体字改为简体后再提交。"
    echo ""
    FAIL=1
  fi
fi

# ── 结果 ──────────────────────────────────────────
if [ "$FAIL" -eq 1 ]; then
  echo "${RED}╔════════════════════════════════════════════╗${NC}"
  echo "${RED}║  提 交 被 拦 截                           ║${NC}"
  echo "${RED}║  修复上述问题后重新 git add + git commit   ║${NC}"
  echo "${RED}║  紧急提交: git commit --no-verify          ║${NC}"
  echo "${RED}╚════════════════════════════════════════════╝${NC}"
  exit 1
fi

echo "${GREEN}╔════════════════════════════════════════════╗${NC}"
echo "${GREEN}║  全 部 检 查 通 过                         ║${NC}"
echo "${GREEN}╚════════════════════════════════════════════╝${NC}"
exit 0
